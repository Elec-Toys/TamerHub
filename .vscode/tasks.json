		{
			"label": "Kill stale platformio processes",
			"type": "shell",
			"command": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Get-CimInstance Win32_Process | Where-Object { $_.Name -match 'platformio|python' -and $_.CommandLine -match 'platformio' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue; Write-Output \"Stopped PID $($_.ProcessId)\" }"
			],
			"isBackground": false
		},
		{
			"label": "Force-stop PlatformIO tools",
			"type": "shell",
			"command": "taskkill",
			"args": [
				"/F",
				"/IM",
				"platformio.exe"
			],
			"isBackground": false
		},
