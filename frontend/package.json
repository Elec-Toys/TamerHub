		"@playwright/test": "^1.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^26.1.1",
		"bits-ui": "2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-compat": "^7.0.2",
		"eslint-plugin-svelte": "^3.21.0",
		"flatbuffers": "^25.9.23",
		"globals": "^17.7.0",
		"prettier": "^3.9.5",
		"prettier-plugin-organize-imports": "^4.3.0",
