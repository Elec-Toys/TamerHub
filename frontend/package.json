		"rollup-plugin-license": "^3.7.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vite-plugin-singlefile": "^2.3.3",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": "^24.12.0",
		"pnpm": "^10.30.1"
